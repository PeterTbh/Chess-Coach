# Caissa — secrets schema. Copy to .env and fill in.

LICHESS_USERNAME=your_lichess_handle
CHESSCOM_USERNAME=your_chesscom_handle

# Local Stockfish binary. Inside Docker the system "stockfish" works; on host
# point at the extracted Apple-silicon build, e.g.:
# STOCKFISH_PATH=/absolute/path/to/Chess-Coach/bin/stockfish/stockfish-macos-m1-apple-silicon
STOCKFISH_PATH=stockfish

# OpenAI — primary (currently only) strategic-advisor LLM provider.
# Sign up at https://platform.openai.com/api-keys.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter — kept in the schema so the OpenRouter client in
# src/advisor/llm.py can be re-enabled without code surgery. Leave the
# key empty if you don't plan to use it.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
