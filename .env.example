# Caissa — secrets schema. Copy to .env and fill in.

LICHESS_USERNAME=your_lichess_handle
CHESSCOM_USERNAME=your_chesscom_handle

# Local Stockfish binary. Inside Docker the system "stockfish" works; on host
# point at the extracted Apple-silicon build, e.g.:
# STOCKFISH_PATH=/absolute/path/to/Chess-Coach/bin/stockfish/stockfish-macos-m1-apple-silicon
STOCKFISH_PATH=stockfish

# OpenRouter — primary strategic-advisor LLM provider. Sign up at
# https://openrouter.ai/keys. Default model is the free Gemma 4 31B;
# switch to a paid one if you hit rate limits.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI — fallback when OpenRouter errors or hallucinates twice. Leave
# OPENAI_API_KEY empty to disable the fallback entirely.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
