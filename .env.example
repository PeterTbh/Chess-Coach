# Caissa — secrets schema. Copy to .env and fill in.

LICHESS_USERNAME=your_lichess_handle
CHESSCOM_USERNAME=your_chesscom_handle

# Local Stockfish binary. Inside Docker the system "stockfish" works; on host
# point at the extracted Apple-silicon build, e.g.:
# STOCKFISH_PATH=/absolute/path/to/Chess-Coach/bin/stockfish/stockfish-macos-m1-apple-silicon
STOCKFISH_PATH=stockfish

# OpenAI — strategic-advisor LLM provider.
# Sign up at https://platform.openai.com/api-keys.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
