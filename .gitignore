# Caissa — gitignore

# User data (kept local)
data/raw_pdfs/
data/extracted/
data/db/
data/models/
data/repertoires/

# Allow .gitkeep markers for empty data dirs
!data/raw_pdfs/.gitkeep
!data/repertoires/.gitkeep
!data/extracted/.gitkeep
!data/db/.gitkeep
!data/models/.gitkeep

# Seed corpus is committed so the app works out-of-the-box
!data/corpus_seed.json

# Local Chroma persistence (auto-built from seed)
data/chroma/

# File types
*.pdf
*.sqlite
*.db
*.gguf

# Local engine binary (~110 MB, machine-specific)
bin/

# Local tooling artefact
.superset/

# Secrets
.env
.streamlit/secrets.toml
# Secrets / captures — never commit
.env

# Scraper is local-only; not published to GitHub
Scraper/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# OS
.DS_Store
*.egg-info/
.venv/
dist/
build/

# IDE
.DS_Store
.idea/
.vscode/
