# Caissa — gitignore

# User data (kept local)
data/repertoires/*
data/chroma/

# Allow .gitkeep markers, the committed seed corpus, and the sample
# Catalan white repertoire that ships with the repo.
!data/repertoires/.gitkeep
!data/repertoires/white.pgn
!data/corpus_seed.json

# Generated file types
*.pdf
*.sqlite
*.db
*.gguf

# Local engine binary (~110 MB, machine-specific)
bin/

# Local tooling artefact
.superset/

# Secrets
.env
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# OS
.DS_Store
dist/
build/

# IDE
.idea/
.vscode/
